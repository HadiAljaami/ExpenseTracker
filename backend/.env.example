# ── Database ──────────────────────────────────────────────────────────────────
DB_PASSWORD=YourStrongPassword@123

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_KEY=YourSuperSecretJwtKey_AtLeast32Characters_ChangeThis!
JWT_ISSUER=ExpenseTrackerAPI
JWT_AUDIENCE=ExpenseTrackerClients
JWT_ACCESS_EXPIRY_MINUTES=60
JWT_REFRESH_EXPIRY_DAYS=7

# ── Email (Gmail example) ─────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=Smart Expense Tracker

# ── App ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Admin (First Admin User) ──────────────────────────────────────────────────
ADMIN_EMAIL=admin@expensetracker.com
ADMIN_PASSWORD=Admin@123456
ADMIN_NAME=System Admin
